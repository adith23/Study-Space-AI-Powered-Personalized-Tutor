# ============================================================
# Terraform Variables — Example
# Copy to terraform.tfvars and fill in actual values.
# This file is gitignored. Never commit real values.
# ============================================================

aws_region   = "us-east-1"
environment  = "production"
project_name = "study-space"

# ECR Public image URIs (from `terraform output` after first ECR creation,
# then built and pushed via CI/CD or manually)
api_image_uri      = "public.ecr.aws/YOUR_ALIAS/study-space-api:latest"
worker_image_uri   = "public.ecr.aws/YOUR_ALIAS/study-space-worker:latest"
frontend_image_uri = "public.ecr.aws/YOUR_ALIAS/study-space-frontend:latest"
