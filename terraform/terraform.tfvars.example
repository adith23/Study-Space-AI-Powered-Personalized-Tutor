# ============================================================
# Terraform Variables — Example
# Copy to terraform.tfvars and fill in actual values.
# This file is gitignored. Never commit real values.
# ============================================================

aws_region   = "us-east-1"
environment  = "production"
project_name = "study-space"

# ECR Private image URIs (from `terraform output` after ECR creation,
# then built and pushed via GitHub Actions bootstrap workflow)
# Format: ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/REPO_NAME:TAG
api_image_uri      = "580647748431.dkr.ecr.us-east-1.amazonaws.com/study-space-api:latest"
worker_image_uri   = "580647748431.dkr.ecr.us-east-1.amazonaws.com/study-space-worker:latest"
frontend_image_uri = "580647748431.dkr.ecr.us-east-1.amazonaws.com/study-space-frontend:latest"
